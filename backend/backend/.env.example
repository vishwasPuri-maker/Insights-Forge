# ==========================
# APPLICATION
# ==========================
APP_NAME=Insights Forge Backend
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=True

# ==========================
# DATABASE  (use postgresql+psycopg:// prefix)
# ==========================
DATABASE_URL=postgresql+psycopg://username:password@host/dbname?sslmode=require

# ==========================
# SECURITY
# ==========================
# Generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_THIS_TO_A_RANDOM_SECRET_KEY
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ==========================
# EMAIL (Brevo transactional API)
# ==========================
BREVO_API_KEY=your_brevo_api_key
EMAIL_FROM=verified_sender@example.com
EMAIL_FROM_NAME=Insights Forge
FRONTEND_URL=http://localhost:5173
EMAIL_VERIFY_TOKEN_EXPIRE_HOURS=24
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30

# ==========================
# REDIS  (not required yet — workers unimplemented)
# ==========================
REDIS_URL=redis://localhost:6379/0

# ==========================
# CORS  (comma-separated frontend origins)
# ==========================
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ==========================
# FILE STORAGE
# ==========================
UPLOAD_DIRECTORY=uploads
MAX_UPLOAD_SIZE_MB=100

# ==========================
# LLM
# ==========================
LLM_PROVIDER=gemini
GEMINI_MODEL=gemini-2.5-flash
GEMINI_API_KEY=
