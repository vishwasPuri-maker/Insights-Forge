{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Apex AI Master Response Schema",
  "description": "Universal response contract for all Llama 3 vLLM inference outputs within Apex AI",
  "type": "object",
  "required": [
    "status",
    "response",
    "analysis_type",
    "confidence",
    "metadata",
    "sources",
    "validation"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["success", "partial", "uncertain", "refused", "fallback", "error"],
      "description": "Execution outcome status"
    },
    "response": {
      "type": "string",
      "description": "The main analytical or conversational response payload"
    },
    "analysis_type": {
      "type": "string",
      "description": "The type of analytics performed (e.g., forecasting, kpi_analysis)"
    },
    "confidence": {
      "type": "object",
      "required": ["score", "level", "explanation", "evidence_count"],
      "properties": {
        "score": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "level": {
          "type": "string",
          "enum": ["VERY_HIGH", "HIGH", "MEDIUM", "LOW", "VERY_LOW", "UNKNOWN"]
        },
        "explanation": {
          "type": "string"
        },
        "evidence_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "metadata": {
      "type": "object",
      "required": ["request_id", "session_id", "timestamp", "model", "version", "latency_ms", "tokens_used"],
      "properties": {
        "request_id": { "type": "string" },
        "session_id": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "model": { "type": "string" },
        "version": { "type": "string" },
        "latency_ms": { "type": "integer", "minimum": 0 },
        "tokens_used": { "type": "integer", "minimum": 0 }
      }
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "source_type", "title", "location", "confidence"],
        "properties": {
          "id": { "type": "string" },
          "source_type": { "type": "string" },
          "title": { "type": "string" },
          "location": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0.0, "maximum": 1.0 }
        }
      }
    },
    "recommendations": {
      "type": "array",
      "items": { "type": "string" }
    },
    "limitations": {
      "type": "array",
      "items": { "type": "string" }
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    },
    "validation": {
      "type": "object",
      "required": ["schema_valid", "safety_valid", "confidence_valid"],
      "properties": {
        "schema_valid": { "type": "boolean" },
        "safety_valid": { "type": "boolean" },
        "confidence_valid": { "type": "boolean" }
      }
    }
  }
}
