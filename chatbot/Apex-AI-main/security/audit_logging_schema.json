{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Apex AI Security Audit Logging Schema",
  "type": "object",
  "required": [
    "event_id",
    "timestamp",
    "severity",
    "attack_type",
    "action_taken",
    "success"
  ],
  "properties": {
    "event_id": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "severity": {
      "type": "string",
      "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"]
    },
    "attack_type": {
      "type": "string",
      "enum": [
        "PROMPT_INJECTION",
        "JAILBREAK",
        "SQL_VIOLATION",
        "HALLUCINATION",
        "ROLE_ESCALATION",
        "POLICY_VIOLATION",
        "ADVERSARIAL_PAYLOAD",
        "SYSTEM_PROMPT_LEAK"
      ]
    },
    "action_taken": { "type": "string" },
    "success": { "type": "boolean" },
    "payload_snippet": { "type": "string" },
    "tenant_id": { "type": "string" }
  }
}
